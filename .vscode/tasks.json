{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "build:webview",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "build"
    },
    {
      "label": "Build All (TS + Webview)",
      "dependsOrder": "sequence",
      "dependsOn": ["Compile TypeScript", "Build Webview"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Compile TypeScript",
      "type": "shell",
      "command": "npm run compile",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "Build Webview",
      "type": "shell",
      "command": "npm run build:webview",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
